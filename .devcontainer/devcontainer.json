{
    "name": "CSC 4260 Project",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "PYTHON_VARIANT": "3.12-bookworm"
        }
    },
    "init": true,
    // Let Dev Containers replace the image's default `python3` command with
    // its keep-alive command so the container stays running during attach.
    "overrideCommand": true,
    "userEnvProbe": "none",

    // Features to add to the container
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/git:1": {}
    },

    // Container runtime settings
    "containerEnv": {
        "PYTHONUNBUFFERED": "1",
        "PIP_DISABLE_PIP_VERSION_CHECK": "1",
        "PIP_NO_CACHE_DIR": "1"
    },
    "remoteEnv": {
        "PATH": "/home/vscode/.local/bin:${containerEnv:PATH}"
    },

    // Port forwarding
    "forwardPorts": [8888],
    "portsAttributes": {
        "8888": { "label": "Jupyter", "onAutoForward": "openPreview" }
    },

    // VS Code extensions
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-toolsai.jupyter",
                "github.copilot"
            ],
            "settings": {
                "python.defaultInterpreterPath": "/usr/local/bin/python3"
            }
        }
    },

    // Post-create command
    "postCreateCommand": "bash .devcontainer/post-create.sh",
    "updateContentCommand": "bash .devcontainer/post-create.sh",

    // Initialization
    "remoteUser": "vscode"
}
